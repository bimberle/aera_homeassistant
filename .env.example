# Aera API Credentials
# Copy this file to .env and fill in your values

# Your Aera account email
AERA_EMAIL=your-email@example.com

# Your Aera account password
AERA_PASSWORD=your-password

# App ID from mitmproxy traffic analysis
# Look for "app_id" in requests to user-field.aylanetworks.com
AERA_APP_ID=

# App Secret from mitmproxy traffic analysis
# Look for "app_secret" in requests to user-field.aylanetworks.com
AERA_APP_SECRET=
