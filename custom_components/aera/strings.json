        "description": "Enter your Aera account credentials.",
        "data": {
          "email": "Email",
          "password": "Password"
        }
      }
    },
    "error": {
      "cannot_connect": "Failed to connect to Aera. Please check your credentials.",
      "no_devices": "No Aera devices found in your account."
    },
