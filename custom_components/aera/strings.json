        "start_time": {
          "name": "Start Time",
          "description": "Start time in HH:MM format"
        },
        "end_time": {
          "name": "End Time",
          "description": "End time in HH:MM format"
        },
        "days": {
          "name": "Days",
          "description": "Days of week (1=Sun, 2=Mon, ..., 7=Sat)"
        },
        "intensity": {
          "name": "Intensity",
          "description": "Intensity level 1-10"
        },
        "active": {
          "name": "Active",
          "description": "Whether the schedule is active"
        }
      }
    },
    "update_schedule": {
      "name": "Update Schedule",
      "description": "Update an existing schedule.",
      "fields": {
        "schedule_key": {
          "name": "Schedule Key",
          "description": "The schedule key to update"
        },
        "schedule_name": {
          "name": "Schedule Name",
          "description": "New display name"
        },
        "start_time": {
          "name": "Start Time",
          "description": "New start time in HH:MM format"
        },
        "end_time": {
          "name": "End Time",
          "description": "New end time in HH:MM format"
        },
        "days": {
          "name": "Days",
          "description": "New days of week"
        },
        "intensity": {
          "name": "Intensity",
          "description": "New intensity level 1-10"
        },
        "active": {
          "name": "Active",
          "description": "Whether the schedule is active"
        }
      }
    },
    "delete_schedule": {
      "name": "Delete Schedule",
      "description": "Delete a schedule.",
      "fields": {
        "schedule_key": {
          "name": "Schedule Key",
          "description": "The schedule key to delete"
        }
      }
    },
    "toggle_schedule": {
      "name": "Toggle Schedule",
      "description": "Enable or disable a schedule.",
      "fields": {
        "schedule_key": {
          "name": "Schedule Key",
          "description": "The schedule key to toggle"
        },
        "active": {
          "name": "Active",
          "description": "Whether the schedule should be active"
        }
      }
    }
