        "room_name": {
          "name": "Room Name",
          "description": "The name of the room where the device is located"
        }
      }
    },
    "get_schedules": {
      "name": "Get Schedules",
      "description": "Get all schedules for an Aera device."
    },
    "refresh_schedules": {
      "name": "Refresh Schedules",
      "description": "Refresh schedules from the cloud."
    },
    "create_schedule": {
      "name": "Create Schedule",
      "description": "Create a new schedule for an Aera device.",
      "fields": {
        "schedule_name": {
          "name": "Schedule Name",
          "description": "Display name for the schedule"
